{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "reasoning_effort": "xhigh"
    },
    "hephaestus": {
      "model": "anthropic/claude-opus-4-6",
      "reasoning_effort": "xhigh"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "reasoning_effort": "high",
      "prompt_append": "Read-only consultant. Debugging + architecture advice. Do not make changes."
    },
    "librarian": {
      "model": "opencode/gpt-5-nano"
    },
    "explore": {
      "model": "opencode/gpt-5-nano"
    },
    "multimodal-looker": {
      "model": "opencode/gpt-5-nano"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "reasoning_effort": "high"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "reasoning_effort": "xhigh"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "reasoning_effort": "xhigh",
      "prompt_append": "Code reviewer. Bugs, security, quality. One-line comments: L<line>: <problem>. <fix>. Severity: 🔴 bug 🟡 risk 🔵 nit."
    },
    "atlas": {
      "model": "anthropic/claude-opus-4-6",
      "reasoning_effort": "xhigh"
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-opus-4-6",
      "reasoning_effort": "xhigh"
    }
  }
}
