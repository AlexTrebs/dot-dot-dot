{
    "custom/wifi-ext": {
        "icon": ["箚ㄿ", "箚쩅", "箚ㄲ", "箚ㄵ", "箚ㄸ"],
        "label": "{ssid}",
        "tooltip": "External Wi-Fi",
        "execute": "~/.config/hyprpanel/scripts/wifi_ext_status.sh",
        "interval": 5000,
        "hideOnEmpty": true,
        "actions": {
            "onLeftClick": "alacritty -e nmtui"
        }
    },
    "custom/mullvad": {
        "icon": "箚뻷",
        "label": "{status}",
        "tooltip": "{tooltip}",
        "execute": "~/.config/hyprpanel/scripts/mullvad_status.sh",
        "interval": 5000,
        "actions": {
            "onLeftClick": "~/.config/hyprpanel/scripts/mullvad_toggle.sh",
            "onMiddleClick": "~/.config/hyprpanel/scripts/mullvad_menu.sh"
        }
    }
}
