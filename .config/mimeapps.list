[Default Applications]
# Web content
text/html=zen.desktop
application/xhtml+xml=zen.desktop
x-scheme-handler/http=zen.desktop
x-scheme-handler/https=zen.desktop
x-scheme-handler/chrome=zen.desktop
application/x-extension-htm=zen.desktop
application/x-extension-html=zen.desktop
application/x-extension-shtml=zen.desktop
application/x-extension-xht=zen.desktop
application/x-extension-xhtml=zen.desktop

# PDF
application/pdf=org.pwmt.zathura.desktop

# Plain text and code files
text/plain=nvim.desktop
text/x-python=nvim.desktop
text/x-csrc=nvim.desktop
text/x-chdr=nvim.desktop
text/x-c++src=nvim.desktop
text/x-c++hdr=nvim.desktop
text/x-java=nvim.desktop
text/x-shellscript=nvim.desktop
text/javascript=nvim.desktop
text/x-lua=nvim.desktop
text/x-ruby=nvim.desktop
text/x-rust=nvim.desktop
text/x-go=nvim.desktop
text/css=nvim.desktop
text/markdown=nvim.desktop
text/x-markdown=nvim.desktop
application/json=nvim.desktop
application/xml=nvim.desktop
application/x-yaml=nvim.desktop
application/toml=nvim.desktop

# Images
image/png=imv.desktop
image/jpeg=imv.desktop
image/gif=imv.desktop
image/webp=imv.desktop
image/bmp=imv.desktop
image/svg+xml=imv.desktop
image/tiff=imv.desktop

# File manager
inode/directory=thunar.desktop

# Video
video/mp4=mpv.desktop
video/x-matroska=mpv.desktop
video/webm=mpv.desktop
video/x-msvideo=mpv.desktop
video/quicktime=mpv.desktop
video/x-flv=mpv.desktop
video/ogg=mpv.desktop

# Audio
audio/mpeg=audacious.desktop
audio/mp4=audacious.desktop
audio/ogg=audacious.desktop
audio/flac=audacious.desktop
audio/x-wav=audacious.desktop
audio/aac=audacious.desktop

# Archives (open with thunar's archive handling)
application/zip=file-roller.desktop
application/x-tar=file-roller.desktop
application/gzip=file-roller.desktop
application/x-bzip2=file-roller.desktop
application/x-xz=file-roller.desktop
application/x-7z-compressed=file-roller.desktop
application/x-rar=file-roller.desktop
application/vnd.rar=file-roller.desktop
x-scheme-handler/ror2mm=r2modman.desktop

[Added Associations]
application/json=nvim.desktop;
text/plain=nvim.desktop;
